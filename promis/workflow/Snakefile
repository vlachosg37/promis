"""Snakemake workflow for PROMIS (PROfiling of Microsatellite InStability).

Each rule orchestrates a step of the tumor-only MSI calling workflow:
1. Extract reads spanning microsatellite loci.
2. Estimate repeat lengths and instability.
3. Summarize and visualize MSI burden per sample.

The workflow expects aligned BAM/CRAM files and reference metadata shipped with the
repository. Configure paths and thresholds in ``config.yaml`` and launch with:

    snakemake -s promis/workflow/Snakefile --use-conda --cores 8 --configfile config.yaml
"""

from pathlib import Path

from promis import __version__
from promis.validation import (
    collect_alignment_files,
    parse_bool,
    parse_call_by,
    parse_float,
    parse_int,
    validate_config,
)
from promis.workflow import resolve_resource_path

WORKFLOW_DIR = Path(workflow.source_path(".")).resolve()
DEFAULT_CONFIG_PATH = WORKFLOW_DIR / "config.yaml"
ENV_FILE = str(Path(workflow.source_path("environment.yml")).resolve())

configfile: str(DEFAULT_CONFIG_PATH)

container: config.get("container_image", "docker://ghcr.io/vlachosg37/promis:latest")


def _resolve_resource_path(key, default_relative):
    """Return the absolute path to a user-supplied or packaged resource."""

    return resolve_resource_path(
        config.get(key, default_relative),
        default_relative,
        str(WORKFLOW_DIR / default_relative),
    )


validation_result = validate_config(config, run_dir=Path.cwd())
if validation_result.errors:
    raise ValueError("Invalid PROMIS config:\n- " + "\n- ".join(validation_result.errors))


repeats = _resolve_resource_path(
    "repeats",
    "database/MSI_loci_hg38_coordinates_metadata_exonic_chr_rem_artefacts.csv",
)
cytoband = _resolve_resource_path("cytoband", "database/cytoBand_hg38.txt")
scripts_dir = _resolve_resource_path("scripts_dir", "scripts")
output_dir = config.get("output_dir", "results/promis")
reference_genome = config.get("reference_genome", "")
reference_arg = f"--reference {reference_genome}" if reference_genome else ""

msi_deviation = parse_float(config.get("msi_deviation", 0.1), "msi_deviation")
min_reads = parse_int(config.get("min_reads", 100), "min_reads")
bq_threshold = parse_float(config.get("bq_threshold", 28), "bq_threshold")
mq_threshold = parse_int(config.get("mq_threshold", 40), "mq_threshold")
min_dev_reads = parse_int(config.get("min_dev_reads", 30), "min_dev_reads")
call_by = parse_call_by(config.get("call_by", "both"))
min_dev_percent = parse_float(config.get("min_dev_percent", 10.0), "min_dev_percent")
min_length_percent = parse_float(config.get("min_length_percent", 5.0), "min_length_percent")
use_GMM = parse_bool(config.get("use_GMM", True), "use_GMM")
balance_tolerance = parse_float(config.get("balance_tolerance", 0.01), "balance_tolerance")
min_total_reads = parse_int(config.get("min_total_reads", 50), "min_total_reads")

config["repeats"] = repeats
config["cytoband"] = cytoband
config["scripts_dir"] = scripts_dir

alignment_files = collect_alignment_files(config, Path.cwd())

if not alignment_files:
    raise ValueError(
        "No alignment files found. Provide 'alignment_files' (or legacy 'bam_files') or 'input_dir' in config.yaml."
    )

if not output_dir:
    raise ValueError("Please specify the 'output_dir' path in the config.")

sample_to_alignment = validation_result.samples
sample_names = list(sample_to_alignment)

rule all:
    """Generate per-sample MSI summaries and the combined cohort table."""

    input:
        expand(
            "{output_dir}/combined_results.csv",
            output_dir=output_dir,
            sample=sample_names,
        ),
        f"{output_dir}/resolved_config.yaml",
        f"{output_dir}/run_metadata.json",
        expand(
            "{output_dir}/{sample}/{sample}_repeat_type_summary.csv",
            output_dir=output_dir,
            sample=sample_names,
        ),
        expand(
            "{output_dir}/{sample}/{sample}_barplot_MSI.pdf",
            output_dir=output_dir,
            sample=sample_names,
        ),
        expand(
            "{output_dir}/{sample}/{sample}_scatter_plot.pdf",
            output_dir=output_dir,
            sample=sample_names,
        ),
        expand(
            "{output_dir}/{sample}/{sample}_heatmap_plot.pdf",
            output_dir=output_dir,
            sample=sample_names,
        ),
        expand(
            "{output_dir}/{sample}/{sample}_cytoband_instability_plot.pdf",
            output_dir=output_dir,
            sample=sample_names,
        ),

rule write_provenance:
    """Write resolved config and run metadata for reproducible reviewer handoff."""

    output:
        resolved_config=f"{output_dir}/resolved_config.yaml",
        run_metadata=f"{output_dir}/run_metadata.json",
    run:
        import json
        import platform
        import sys
        from datetime import datetime, timezone
        from importlib import metadata
        from pathlib import Path

        import yaml

        Path(output.resolved_config).parent.mkdir(parents=True, exist_ok=True)

        thresholds = {
            "msi_deviation": msi_deviation,
            "min_reads": min_reads,
            "bq_threshold": bq_threshold,
            "mq_threshold": mq_threshold,
            "min_dev_reads": min_dev_reads,
            "call_by": call_by,
            "min_dev_percent": min_dev_percent,
            "min_length_percent": min_length_percent,
            "use_GMM": use_GMM,
            "balance_tolerance": balance_tolerance,
            "min_total_reads": min_total_reads,
        }
        resolved_config = dict(config)
        resolved_config.update(
            {
                "output_dir": output_dir,
                "repeats": repeats,
                "cytoband": cytoband,
                "scripts_dir": scripts_dir,
                "reference_genome": reference_genome,
                "alignment_files": alignment_files,
                "samples": sample_to_alignment,
                "thresholds": thresholds,
            }
        )
        Path(output.resolved_config).write_text(
            yaml.safe_dump(resolved_config, sort_keys=False),
            encoding="utf-8",
        )

        try:
            snakemake_version = metadata.version("snakemake")
        except metadata.PackageNotFoundError:
            snakemake_version = "unknown"

        run_metadata = {
            "promis_version": __version__,
            "snakemake_version": snakemake_version,
            "python_version": sys.version,
            "platform": platform.platform(),
            "timestamp_utc": datetime.now(timezone.utc).isoformat(),
            "run_directory": str(Path.cwd()),
            "workflow_directory": str(WORKFLOW_DIR),
            "sample_count": len(sample_names),
            "samples": sample_to_alignment,
            "resources": {
                "repeats": repeats,
                "cytoband": cytoband,
                "scripts_dir": scripts_dir,
            },
            "thresholds": thresholds,
        }
        Path(output.run_metadata).write_text(
            json.dumps(run_metadata, indent=2, sort_keys=True) + "\n",
            encoding="utf-8",
        )

rule extract_reads:
    """Pull high-quality reads spanning MSI loci from each alignment file."""

    input:
        alignment=lambda wildcards: sample_to_alignment[wildcards.sample],
        repeats=repeats,
    output:
        extracted_csv="{output_dir}/{sample}/{sample}_extracted_reads.csv",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/extract_MSI_sequences.py" \
            -a {input.alignment} \
            -r {input.repeats} \
            -o {output.extracted_csv} \
            {reference_arg} \
            --bq_threshold {bq_threshold} \
            --mq_threshold {mq_threshold} \
            --min_reads {min_reads}
        """

rule analyze_repeats:
    """Estimate microsatellite lengths per locus and sample."""

    input:
        extracted_csv="{output_dir}/{sample}/{sample}_extracted_reads.csv",
        repeats=repeats,
    output:
        repeats_csv="{output_dir}/{sample}/{sample}_repeats_analysis.csv",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/analyze_MSI_lengths.py" \
            -e "{input.extracted_csv}" \
            -r "{input.repeats}" \
            -o "{output.repeats_csv}" \
            -t {msi_deviation}
        """

rule analyze_distribution:
    """Classify loci as stable/unstable using configurable thresholds."""

    input:
        repeats_csv="{output_dir}/{sample}/{sample}_repeats_analysis.csv",
    output:
        distribution_csv="{output_dir}/{sample}/{sample}_distribution_analysis.csv",
    params:
        gmm_flag=lambda wildcards: "--use_GMM" if use_GMM else "",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/analyze_MSI_distribution.py" \
            -i {input.repeats_csv} \
            -o {output.distribution_csv} \
            --call_by {call_by} \
            --min_dev_reads {min_dev_reads} \
            --min_dev_percent {min_dev_percent} \
            --min_length_percent {min_length_percent} \
            {params.gmm_flag} \
            --balance_tolerance {balance_tolerance} \
            --min_total_reads {min_total_reads}
        """

rule plot_msi_status:
    """Plot MSI status barplots summarizing unstable loci."""

    input:
        distribution_csv="{output_dir}/{sample}/{sample}_distribution_analysis.csv",
    output:
        barplot="{output_dir}/{sample}/{sample}_barplot_MSI.pdf",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/plot_MSI_results.py" -i {input.distribution_csv} -o {output.barplot}
        """

rule plot_region_stats:
    """Generate per-region scatter, heatmap, and cytoband visualizations."""

    input:
        distribution_csv="{output_dir}/{sample}/{sample}_distribution_analysis.csv",
    output:
        scatter_plot="{output_dir}/{sample}/{sample}_scatter_plot.pdf",
        heatmap_plot="{output_dir}/{sample}/{sample}_heatmap_plot.pdf",
        cytoband_plot="{output_dir}/{sample}/{sample}_cytoband_instability_plot.pdf",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/plot_region_stats.py" \
        -d {input.distribution_csv} \
        -s {output.scatter_plot} \
        -m {output.heatmap_plot} \
        -c {cytoband} \
        --cytoband_output {output.cytoband_plot}
        """


rule analyze_repeat_types:
    """Summarize instability by repeat unit and length categories."""

    input:
        lengths_csv="{output_dir}/{sample}/{sample}_repeats_analysis.csv",
    output:
        summary_csv="{output_dir}/{sample}/{sample}_repeat_type_summary.csv",
        instability_plot="{output_dir}/{sample}/{sample}_repeat_unit_instability_barplot.pdf",
        length_vs_instability_plot="{output_dir}/{sample}/{sample}_repeat_length_vs_instability_scatterplot.pdf",
    conda:
        ENV_FILE
    shell:
        """
        python "{scripts_dir}/repeat_type_stats.py" \
            -l {input.lengths_csv} \
            -o $(dirname {output.summary_csv}) \
            --plot_instability \
            --plot_length_vs_instability \
            --sample {wildcards.sample}
        """

rule combine_results:
    input:
        expand(
            "{output_dir}/{sample}/{sample}_distribution_analysis.csv",
            output_dir=output_dir,
            sample=sample_names,
        )
    output:
        combined_csv = "{output_dir}/combined_results.csv"
    conda:
        ENV_FILE
    run:
        import pandas as pd
        import re
        from pathlib import Path

        columns = [
            "Score",
            "Unstable regions",
            "Total regions",
            "Call status",
            "Sample",
            "Evaluable_Loci",
            "Unstable_Loci",
            "Score_Percent",
            "Score_Fraction",
            "QC_Status",
        ]
        inputs = list(input)
        if not inputs:
            pd.DataFrame(columns=columns).to_csv(output.combined_csv, index=False)
            return

        combined_rows = []

        for result_file in inputs:
            df = pd.read_csv(result_file)
            summary_row = df[df["Chromosome"] == "Summary"]
            sample_name = Path(result_file).parent.name

            if not summary_row.empty:
                summary = summary_row.iloc[0]
                if "MSI_Score" in summary_row.columns:
                    score = float(summary["MSI_Score"])
                    unstable_count = int(summary["Unstable_Regions"])
                    total_regions = int(summary["Total_Regions"])
                    call_status = str(summary.get("Call_Status", "PASS"))
                    unstable_regions = f"{unstable_count}/{total_regions}"
                else:
                    status_str = str(summary["MSI_Status"])
                    match = re.match(r"([\d.]+)%.*\((\d+)/(\d+)", status_str)
                    if not match:
                        continue
                    score = float(match.group(1))
                    unstable_count = int(match.group(2))
                    total_regions = int(match.group(3))
                    unstable_regions = f"{unstable_count}/{total_regions}"
                    call_status = "PASS"
                qc_status = call_status
                if total_regions == 0:
                    score = pd.NA
                    score_fraction = pd.NA
                    qc_status = "NO_EVALUABLE_LOCI"
                    call_status = "NO_EVALUABLE_LOCI"
                else:
                    score_fraction = score / 100.0
                combined_rows.append({
                    "Score": score,
                    "Unstable regions": unstable_regions,
                    "Total regions": total_regions,
                    "Call status": call_status,
                    "Sample": sample_name,
                    "Evaluable_Loci": total_regions,
                    "Unstable_Loci": unstable_count,
                    "Score_Percent": score,
                    "Score_Fraction": score_fraction,
                    "QC_Status": qc_status,
                })

        combined_df = pd.DataFrame(combined_rows, columns=columns)
        combined_df.to_csv(output.combined_csv, index=False)
